# Copy to .env at repo root: cp .env.example .env
# Never commit .env — it contains account credentials and JWT tokens.

# Postgres (host port 5435 when using docker compose)
DATABASE_URL=postgresql://safeway:safeway@localhost:5435/safeway_analytics

# Albertsons / Safeway account identifiers (from HAR or browser session)
CLUBCARD=
HHID=
HOME_STORE_ID=305
OKTA_USER_ID=

# JWT Bearer token — paste from HAR on first setup; TokenManager refreshes via Okta
JWT_TOKEN=

# GraphQL API
PORT=4001
NODE_ENV=development

# React dashboard (Vite dev server)
VITE_GRAPHQL_URL=http://localhost:4001/graphql
VITE_API_PROXY_TARGET=http://127.0.0.1:4001
