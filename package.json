{
  "name": "safeway-analytics",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "predev": "pnpm --filter @safeway-analytics/shared build",
    "dev": "pnpm --filter @safeway-analytics/api dev",
    "dev:all": "concurrently -n api,web -c blue,magenta \"pnpm --filter @safeway-analytics/api dev\" \"pnpm --filter @safeway-analytics/web dev\"",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "db:migrate": "docker compose --profile tools run --rm flyway",
    "db:repair": "docker compose --profile tools run --rm flyway repair",
    "ingest": "pnpm --filter @safeway-analytics/ingestion ingest",
    "ingest:offers": "pnpm --filter @safeway-analytics/ingestion ingest:offers",
    "probe": "pnpm --filter @safeway-analytics/ingestion probe"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2"
  }
}
